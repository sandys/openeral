# PostgreSQL connection (bundled postgres is used by default)
# DATABASE_URL=postgres://user:pass@your-host/your-db

# Anthropic API key for Claude Code
# ANTHROPIC_API_KEY=sk-ant-...

# Workspace ID (default: "default")
# WORKSPACE_ID=my-agent

# Override default auto-created directories (JSON)
# WORKSPACE_CONFIG={"auto_dirs":[".claude",".claude/memory"],"seed_files":{}}
